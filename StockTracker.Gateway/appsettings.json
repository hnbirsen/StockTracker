{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/identity" }
        ]
      },
      "product": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/product/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/product" }
        ]
      },
      "brand-detection": {
        "ClusterId": "brand-detection-cluster",
        "Match": {
          "Path": "/api/brand-detection/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/brand-detection" }
        ]
      },
      "store-reference": {
        "ClusterId": "store-reference-cluster",
        "Match": {
          "Path": "/api/store-reference/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/store-reference" }
        ]
      },
      "search-orchestrator": {
        "ClusterId": "search-orchestrator-cluster",
        "Match": {
          "Path": "/api/search/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/search" }
        ]
      },
      "subscription": {
        "ClusterId": "subscription-cluster",
        "Match": {
          "Path": "/api/subscriptions/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/subscriptions" }
        ]
      },
      "billing": {
        "ClusterId": "billing-cluster",
        "Match": {
          "Path": "/api/billing/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/billing" }
        ]
      },
      "notification": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api/notifications" }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-dest": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-dest": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "brand-detection-cluster": {
        "Destinations": {
          "brand-detection-dest": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "store-reference-cluster": {
        "Destinations": {
          "store-reference-dest": {
            "Address": "http://localhost:5004"
          }
        }
      },
      "search-orchestrator-cluster": {
        "Destinations": {
          "search-orchestrator-dest": {
            "Address": "http://localhost:5005"
          }
        }
      },
      "subscription-cluster": {
        "Destinations": {
          "subscription-dest": {
            "Address": "http://localhost:5006"
          }
        }
      },
      "billing-cluster": {
        "Destinations": {
          "billing-dest": {
            "Address": "http://localhost:5007"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-dest": {
            "Address": "http://localhost:5008"
          }
        }
      }
    }
  }
}